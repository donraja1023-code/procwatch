# ----------------------------
# Python bytecode
# ----------------------------
__pycache__/          # Python stores compiled bytecode here
*.py[cod]             # Compiled Python files (.pyc, .pyo)
*$py.class            # Compiled class files
# Reason: unnecessary, regenerated automatically, can cause conflicts

# ----------------------------
# C extensions
# ----------------------------
*.so                   # Shared object files from compiled extensions
# Reason: build artifacts, platform-specific

# ----------------------------
# Distribution / Packaging
# ----------------------------
build/                 # Temporary build directory for setuptools
dist/                  # Distribution archives (sdist, wheel)
*.egg-info/            # Metadata for editable installs
*.egg                  # Older egg packages
.eggs/                 # Egg cache
# Reason: generated during packaging, never source-controlled

# ----------------------------
# Installer logs
# ----------------------------
pip-log.txt
pip-delete-this-directory.txt
# Reason: local logs, not needed in repo

# ----------------------------
# Unit test / coverage reports
# ----------------------------
htmlcov/               # HTML coverage reports
.coverage              # Coverage data file
.coverage.*            # Coverage backups
.cache                 # Cache directory for pytest or other tools
nosetests.xml          # Test reports
coverage.xml           # Coverage report file for CI
*.cover                # Generic coverage file
*.py,cover             # Coverage files per source
.hypothesis/           # Hypothesis testing cache
.pytest_cache/         # pytest caching
# Reason: generated by tests, irrelevant to source code, can differ per machine

# ----------------------------
# Virtual environments
# ----------------------------
venv/
env/
ENV/
.venv/ 
# Reason: large, local, platform-dependent, and should be reproducible via requirements.txt

# ----------------------------
# Jupyter Notebook checkpoints
# ----------------------------
.ipynb_checkpoints
# Reason: temporary files, clutter repository

# ----------------------------
# IDEs / Editors
# ----------------------------
.vscode/               # VSCode settings
.idea/                 # PyCharm / IntelliJ settings
*.swp                  # Vim swap files
*~                     # Backup files
*.iml                  # PyCharm project module files
*.iws                  # PyCharm workspace files
out/                   # PyCharm output folders
# Reason: user/editor-specific, different per developer, irrelevant to project

# ----------------------------
# Logs
# ----------------------------
*.log
# Reason: runtime logs, not part of source code

# ----------------------------
# Temporary files
# ----------------------------
*.tmp
tmp
*.bak
# Reason: temporary files created by editors or tools

# ----------------------------
# PyPI / Packaging artifacts
# ----------------------------
*.whl
*.tar.gz
*.zip
# Reason: release artifacts, generated during build/publish, not source code